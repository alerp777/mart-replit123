# ─── AJKMart Environment Template ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
# ── Quick-start by environment ────────────────────────────────────────────────
#
#  Replit (zero-touch):
#    All secrets are stored in the Replit Secrets panel (padlock icon).
#    Just press Run — no manual setup needed.
#
#  GitHub Codespaces / Local:
#    Real secrets are stored encrypted in .env.enc (password: Khan@123.com).
#    Run `pnpm run start:all` and the script auto-decrypts on startup.
#    Override the password via:  export ENV_PASSWORD=your-password
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ajkmart

# ── JWT / Auth Secrets ────────────────────────────────────────────────────────
# Generate strong values with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
ADMIN_JWT_SECRET=
ADMIN_ACCESS_TOKEN_SECRET=
ADMIN_REFRESH_TOKEN_SECRET=
ADMIN_CSRF_SECRET=
ADMIN_REFRESH_SECRET=
ADMIN_SECRET=
VENDOR_JWT_SECRET=
RIDER_JWT_SECRET=

# ── Security ──────────────────────────────────────────────────────────────────
ENCRYPTION_MASTER_KEY=
ERROR_REPORT_HMAC_SECRET=
JWT_ISSUER=ajkmart-dev
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:19006,http://localhost:5000

# ── Admin Seed ────────────────────────────────────────────────────────────────
ADMIN_SEED_USERNAME=superadmin
ADMIN_SEED_PASSWORD=Admin@123
ADMIN_SEED_EMAIL=admin@ajkmart.com
ADMIN_SEED_NAME=Super Admin

# ── Port Configuration ────────────────────────────────────────────────────────
PORT=5000
PORT_FALLBACK_ENABLE=true
PORT_MAX_RETRIES=10
ADMIN_DEV_PORT=3000
ADMIN_PORT_OVERRIDE=3000
VENDOR_DEV_PORT=3002
RIDER_DEV_PORT=3003

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5000
ADMIN_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:19006
CLIENT_URL=http://localhost:4200

# ── Feature Flags ─────────────────────────────────────────────────────────────
ADMIN_LEGACY_AUTH_DISABLED=0
ADMIN_PASSWORD_RESET_TOKEN_TTL_MIN=15
LOG_LEVEL=debug
NODE_ENV=development

# ── Expo / Vite ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_DOMAIN=localhost:5000
VITE_API_BASE_URL=http://localhost:5000
VITE_API_PROXY_TARGET=http://127.0.0.1:5000

# ── Third-Party Integrations (optional — leave blank if unused) ───────────────
GEMINI_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=
SMTP_HOST=
GOOGLE_MAPS_API_KEY=
OSRM_API_URL=
REDIS_URL=
SENTRY_DSN=
SENTRY_WEBHOOK_SECRET=

# ── Push Notifications (VAPID) ────────────────────────────────────────────────
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT_EMAIL=

# ── S3-Compatible Object Storage (optional) ───────────────────────────────────
STORAGE_BUCKET_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_NAME=
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1

# ── WebRTC / TURN (optional) ──────────────────────────────────────────────────
VITE_TURN_SERVER_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# ── Production / Deployment ───────────────────────────────────────────────────
ALLOWED_DOMAINS=
DB_POOL_MAX=10
