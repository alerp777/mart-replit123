[rules]

[rules.formatter]

[rules.formatter.fileExtensions]

[rules.formatter.fileExtensions.".ts"]
id = "module:nodejs-24/languageServer:typescript-language-server"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 3003
externalPort = 3003

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 4200
externalPort = 4200
