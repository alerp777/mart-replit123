modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

run = "nix develop --command bash -lc 'pnpm install && pnpm run start:all'"

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/admin: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vendor App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rider App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Ajkmart Customer App"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --frozen-lockfile && cd artifacts/api-server && pnpm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "artifacts/admin: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/admin && ADMIN_DEV_PORT=3001 BASE_PATH=/admin/ pnpm run dev"
waitForPort = 3001

[[workflows.workflow]]
name = "Vendor App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --frozen-lockfile && cd artifacts/vendor-app && VENDOR_DEV_PORT=3002 pnpm run dev"
waitForPort = 3002

[[workflows.workflow]]
name = "Rider App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --frozen-lockfile && cd artifacts/rider-app && pnpm run dev"
waitForPort = 3003

[[workflows.workflow]]
name = "Ajkmart Customer App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --frozen-lockfile && cd artifacts/ajkmart && PORT=4200 pnpm run dev:web"
waitForPort = 4200

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 480000

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "openssl", "pkg-config", "psmisc", "rustc", "tree", "uwhoisd"]

[userenv]

