modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

run = "nix develop --command bash -lc 'pnpm install && pnpm run start:all'"

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/admin: web"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --no-frozen-lockfile && cd artifacts/api-server && pnpm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "artifacts/admin: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "ADMIN_PORT_OVERRIDE=3000 ADMIN_DEV_PORT=3000 cd artifacts/admin && node node_modules/vite/bin/vite.js --config vite.config.ts --host 0.0.0.0"
waitForPort = 3000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 480000

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "openssl", "pkg-config", "psmisc", "rustc", "tree", "uwhoisd"]

[userenv]

[userenv.shared]
ADMIN_SEED_USERNAME = "superadmin"
ADMIN_SEED_PASSWORD = "Admin@123"
ADMIN_SEED_NAME = "Super Admin"
PORT = "5000"
PORT_FALLBACK_ENABLE = "true"
PORT_MAX_RETRIES = "10"
LOG_LEVEL = "debug"
